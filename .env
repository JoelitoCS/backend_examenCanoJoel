PORT=3001
NODE_ENV=development

# Tipo de almacenamiento: 'array' (en memoria) o 'mongodb' (base de datos)
# Usa 'array' para desarrollo rápido sin base de datos
# Usa 'mongodb' cuando tengas MongoDB configurado
STORAGE_TYPE=array

# Variables de MongoDB (descomenta cuando uses mongodb)
# MONGODB_URI=mongodb://localhost:27017/atunes
# MONGODB_USER=tu_usuario
# MONGODB_PASSWORD=tu_contraseña
